@model RestaurantsIndexViewModel
@{
    ViewData["Title"] = "Рестораны";
    int totalPages = Model.Page.TotalCount > 0 ? (int)Math.Ceiling((double)Model.Page.TotalCount / 20.0) : 1;
}

<div class="d-flex align-items-center mb-4 gap-3">
    <h2 class="mb-0">Рестораны</h2>
    <span class="badge bg-secondary fs-6">@Model.Page.TotalCount</span>
    <a asp-action="Create" class="btn btn-success ms-auto">
        <i class="bi bi-plus-circle me-1"></i>Добавить ресторан
    </a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Поиск по названию" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search me-1"></i>Найти
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-1">Сбросить</a>
    </div>
</form>

@if (!Model.Page.Items.Any())
{
    <div class="alert alert-info">Рестораны не найдены.</div>
}
else
{
    <div class="row g-3">
        @foreach (var r in Model.Page.Items)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(r.LogoUrl))
                    {
                        <img src="@r.LogoUrl" class="card-img-top" style="height:160px;object-fit:cover;" alt="@r.Name" />
                    }
                    else
                    {
                        <div class="bg-secondary d-flex align-items-center justify-content-center" style="height:80px;">
                            <i class="bi bi-building text-white fs-1"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@r.Name</h5>
                        <p class="card-text text-muted small">
                            <i class="bi bi-geo-alt me-1"></i>@r.Address
                        </p>
                        @if (!string.IsNullOrEmpty(r.Description))
                        {
                            <p class="card-text small text-secondary">@r.Description</p>
                        }
                    </div>
                    <div class="card-footer d-flex gap-2 bg-transparent">
                        <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Редактировать
                        </a>
                        <form asp-action="Delete" method="post"
                              onsubmit="return confirm('Удалить ресторан «@r.Name»?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@r.Id" />
                            <input type="hidden" name="search" value="@Model.Search" />
                            <input type="hidden" name="page" value="@Model.CurrentPage" />
                            <button class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i>Удалить
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
