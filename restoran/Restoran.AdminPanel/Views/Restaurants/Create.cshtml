@model CreateRestaurantDto
@{
    ViewData["Title"] = "Добавить ресторан";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Назад
    </a>
    <h2 class="mb-0">Добавить ресторан</h2>
</div>

<div class="card shadow-sm" style="max-width:560px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger py-2"
                 style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Название *</label>
                <input asp-for="Name" class="form-control" placeholder="Название ресторана" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label fw-semibold">Адрес *</label>
                <input asp-for="Address" class="form-control" placeholder="ул. Примерная, д. 1" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Краткое описание"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="LogoUrl" class="form-label fw-semibold">Ссылка на логотип</label>
                <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check2 me-1"></i>Создать
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
